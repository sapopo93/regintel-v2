{
  "name": "regintel-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gate": "tsx scripts/gate.ts",
    "test": "vitest run",
    "validate:versions": "tsx scripts/validate-version-immutability.ts",
    "api:dev": "cd apps/api && pnpm dev",
    "web:dev": "cd apps/web && pnpm dev",
    "playwright": "pnpm --dir apps/web playwright test",
    "build": "pnpm --dir apps/web build && pnpm --dir apps/api build",
    "deploy:prod": "bash deploy.sh"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.10.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "yaml": "^2.3.0"
  }
}
